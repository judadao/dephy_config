CC ?= gcc
CFLAGS ?= -Wall -Wextra -std=c11 -g -D_POSIX_C_SOURCE=200809L
OUTDIR ?= build_out

.PHONY: test clean

$(OUTDIR):
	mkdir -p $(OUTDIR)

$(OUTDIR)/smoke_config_store: tests/smoke_config_store.c src/config_store.c include/dephy_config/config_store.h | $(OUTDIR)
	$(CC) $(CFLAGS) -Iinclude tests/smoke_config_store.c src/config_store.c -o $@

test: $(OUTDIR)/smoke_config_store
	$<

clean:
	rm -rf $(OUTDIR)
